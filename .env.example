# Benchmark API keys — copy to .env and fill in.
# These override pi's global auth.json, so you can use a
# separate key for benchmark cost tracking.

# OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# GOOGLE_GEMINI_API_KEY=...
# MISTRAL_API_KEY=...
# DEEPSEEK_API_KEY=...
# XAI_API_KEY=...
